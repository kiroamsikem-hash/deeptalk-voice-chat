{
  "name": "sesli-konusma-uygulamasi",
  "version": "1.0.0",
  "description": "Arkadaşlar için masaüstü sesli konuşma uygulaması",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron": "^27.0.0",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.kiro.seslikonusma",
    "productName": "Sesli Konuşma",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "keywords": ["voice", "chat", "webrtc", "real-time", "desktop", "electron"],
  "author": "Kiro",
  "license": "MIT"
}